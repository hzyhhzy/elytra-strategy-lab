    "issues": "https://github.com/hzyhhzy/elytra-strategy-lab/issues"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "local.elytra.optima.ElytraOptimaClient"
    ],
    "modmenu": [
      "local.elytra.optima.ElytraOptimaModMenu"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
